    def edit_teacher(self, tid):
        colors = THEMES[self.theme]
        top = tk.Toplevel(self.root); top.title("Преподаватель"); top.geometry("450x350"); top.configure(bg=colors["bg"])
        c=db(); t = c.execute("SELECT * FROM teachers WHERE id=?", (tid,)).fetchone() if tid else None; c.close()
        tk.Label(top, text="✏️ Преподаватель", font=("Segoe UI", 16, "bold"), bg=colors["bg"], fg=colors["text"]).pack(pady=15)
        ents={}
        for l,k in [("Имя*", "name"), ("Описание", "desc"), ("Цена*", "price"), ("Рейтинг", "rating")]:
            tk.Label(top, text=l, font=("Segoe UI", 10), bg=colors["bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            e=ttk.Entry(top, style="Soft.TEntry"); ents[k]=e
            if t: e.insert(0, t["description"] if k=="desc" else (t["price"] if k!="rating" else t["rating"]))
            e.pack(fill="x", padx=30, pady=3)
        err=tk.Label(top, text="", font=("Segoe UI", 9), bg=colors["bg"], fg=colors["danger"]); err.pack()
        def save():
            name, desc, price, rating = ents["name"].get().strip(), ents["desc"].get(), ents["price"].get().strip(), ents["rating"].get().strip() or 0
            if not name or len(name)<3: err.config(text="Имя минимум 3 символа"); return
            try: price=float(price); rating=float(rating)
