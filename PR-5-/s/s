import tkinter as tk
from tkinter import ttk, messagebox
import sqlite3
import hashlib
import re
import csv
from datetime import datetime
from pathlib import Path

DB = "kabanford.db"

def db():
    conn = sqlite3.connect(DB)
    conn.row_factory = sqlite3.Row
    return conn

def init_db():
    c = db()
    c.executescript("""
        CREATE TABLE IF NOT EXISTS users(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            email TEXT UNIQUE,
            password TEXT,
            role TEXT DEFAULT 'student',
            created_at TEXT
        );
        CREATE TABLE IF NOT EXISTS teachers(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT,
            description TEXT,
            price REAL,
            rating REAL
        );
        CREATE TABLE IF NOT EXISTS enrollments(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            teacher_id INTEGER,
            date TEXT,
            FOREIGN KEY(user_id) REFERENCES users(id),
            FOREIGN KEY(teacher_id) REFERENCES teachers(id)
        );
    """)
    
    if not c.execute("SELECT COUNT(*) FROM teachers").fetchone()[0]:
        c.execute("INSERT INTO teachers(name, description, price, rating) VALUES(?,?,?,?)",
                 ("Кабанов Никита", "Знает все предметы", 3500, 5.0))
        c.execute("INSERT INTO teachers(name, description, price, rating) VALUES(?,?,?,?)",
                 ("Смирнов Данил", "Ничего не знает", 500, 2.0))
    
    if not c.execute("SELECT COUNT(*) FROM users WHERE email='admin@kabanford.ru'").fetchone()[0]:
        c.execute("INSERT INTO users(email,password,role) VALUES(?,?,?)",
                 ("admin@kabanford.ru", hashlib.sha256("admin123".encode()).hexdigest(), "admin"))
    
    c.commit()
    c.close()

