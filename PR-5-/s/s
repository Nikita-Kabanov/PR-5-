    def edit_course(self, cid):
        colors = THEMES[self.theme]
        top = tk.Toplevel(self.root); top.title("Курс"); top.geometry("450x400"); top.configure(bg=colors["bg"])
        c=db(); crs = c.execute("SELECT * FROM courses WHERE id=?", (cid,)).fetchone() if cid else None
        teachers = c.execute("SELECT id, name FROM teachers").fetchall(); c.close()
        tk.Label(top, text="📚 Курс", font=("Segoe UI", 16, "bold"), bg=colors["bg"], fg=colors["text"]).pack(pady=15)
        ents={}
        for l,k in [("Название*", "title"), ("Описание", "desc")]:
            tk.Label(top, text=l, font=("Segoe UI", 10), bg=colors["bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            e=ttk.Entry(top, style="Soft.TEntry"); ents[k]=e
            if crs: e.insert(0, crs["description"] if k=="desc" else crs["title"])
            e.pack(fill="x", padx=30, pady=3)
        tk.Label(top, text="Преподаватель", font=("Segoe UI", 10), bg=colors["bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
        tv = tk.StringVar(); cb = ttk.Combobox(top, textvariable=tv, style="Soft.TCombobox", state="readonly")
        cb["values"] = [f"{t['id']}: {t['name']}" for t in teachers]
        if crs: cb.set(f"{crs['teacher_id']}: {[t['name'] for t in teachers if t['id']==crs['teacher_id']][0]}")
        cb.pack(fill="x", padx=30, pady=3); ents["tid"]=lambda: int(tv.get().split(":")[0]) if tv.get() else None
        for l,k in [("Цена*", "price"), ("Часы*", "hours")]:
            tk.Label(top, text=l, font=("Segoe UI", 10), bg=colors["bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            e=ttk.Entry(top, style="Soft.TEntry"); ents[k]=e
            if crs: e.insert(0, crs["price"] if k=="price" else crs["duration_hours"])
            e.pack(fill="x", padx=30, pady=3)
        err=tk.Label(top, text="", font=("Segoe UI", 9), bg=colors["bg"], fg=colors["danger"]); err.pack()
        def save():
            title, desc = ents["title"].get().strip(), ents["desc"].get()
            if not title or len(title)<3: err.config(text="Название минимум 3 символа"); return
            try: price=float(ents["price"].get().strip()); hours=int(ents["hours"].get().strip())
            except: err.config(text="Цена и часы должны быть числами"); return
            c=db()
            if c.execute("SELECT id FROM courses WHERE title=? AND id!=?", (title, cid or 0)).fetchone(): err.config(text="Название уже занято"); c.close(); return
            tid = ents["tid"]()
            if cid: c.execute("UPDATE courses SET title=?, description=?, teacher_id=?, price=?, duration_hours=? WHERE id=?", (title, desc, tid, price, hours, cid))
            else: c.execute("INSERT INTO courses(title,description,teacher_id,price,duration_hours) VALUES(?,?,?,?,?)", (title, desc, tid, price, hours))
            c.commit(); c.close(); messagebox.showinfo("Успех", "Сохранено!"); top.destroy(); self.show_courses()
            log_action(self.current_user["email"], self.current_user["role"], "UPDATE_COURSE" if cid else "CREATE_COURSE", "SUCCESS")
        ttk.Button(top, text="💾 Сохранить", style="Success.TButton", command=save).pack(pady=15)

