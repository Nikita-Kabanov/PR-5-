    def delete_user(self, user_id, email):
        if not messagebox.askyesno("Подтверждение", 
                f"Вы действительно хотите удалить запись №{user_id}? Это действие нельзя отменить, и все ваши котики умрут от грусти"):
            return
        c = db()
        c.execute("DELETE FROM users WHERE id=?", (user_id,))
        c.commit(); c.close()
        log_action(self.current_user["email"], self.current_user["role"], "DELETE_USER", "SUCCESS")
        messagebox.showinfo("Удалено", "Пользователь удалён"); self.show_admin_panel()

