    def logout(self):
        if not messagebox.askyesno("Выход", "Вы уверены, что хотите выйти?"):
            return
        email = self.current_user["email"] if self.current_user else "guest"
        role = self.current_user["role"] if self.current_user else "guest"
        log_action(email, role, "LOGOUT", "SUCCESS")
        self.current_user = None
        self.show_dashboard()

