    def export_csv(self, table):
        c=db(); rows=c.execute(f"SELECT * FROM {table}").fetchall(); c.close()
        if not rows: messagebox.showinfo("Экспорт", "Нет данных"); return
        path=f"exports/{table}_{datetime.now().strftime('%Y%m%d')}.csv"
        Path("exports").mkdir(exist_ok=True)
        with open(path, "w", newline="", encoding="utf-8-sig") as f:
            w=csv.writer(f); w.writerow(rows[0].keys())
            for r in rows: w.writerow(r)
        messagebox.showinfo("Экспорт", f"Сохранено: {path}")
        log_action(self.current_user["email"] if self.current_user else "guest", self.current_user["role"] if self.current_user else "guest", f"EXPORT_{table.upper()}", "SUCCESS")

