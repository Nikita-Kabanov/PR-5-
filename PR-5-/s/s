    def show_login(self):
        self.log_and_show("login")
        self.clear_screen()
        colors = THEMES[self.theme]
        ttk.Button(self.root, text="← Назад", style="Soft.TButton", command=self.show_dashboard).place(x=20, y=20)
        frm = tk.Frame(self.root, bg=colors["card_bg"], highlightbackground=colors["card_border"], highlightthickness=1)
        frm.place(relx=0.5, rely=0.5, anchor="center", width=400, height=360)
        tk.Label(frm, text="🔐 Вход", font=("Segoe UI", 20, "bold"), bg=colors["card_bg"], fg=colors["text"]).pack(pady=20)
        for lbl, key, show in [("Email", "email", False), ("Пароль", "password", True)]:
            tk.Label(frm, text=lbl, font=("Segoe UI", 10), bg=colors["card_bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            e = ttk.Entry(frm, style="Soft.TEntry")
            if show: e.config(show="*")
            e.pack(fill="x", padx=30, pady=4)
            setattr(frm, f"{key}_entry", e)
        err = tk.Label(frm, text="", font=("Segoe UI", 9), bg=colors["card_bg"], fg=colors["danger"])
        err.pack()
        def do():
            email, pwd = frm.email_entry.get().strip(), frm.password_entry.get()
            if not email or not pwd: err.config(text="Заполните все поля"); return
            locked, rem = login_manager.is_locked(email)
            if locked: err.config(text=f"Слишком много попыток. Ждите {rem}с."); frm.after(1000, do); return
            c = db()
            user = c.execute("SELECT * FROM users WHERE email=? AND password=?", (email, hashlib.sha256(pwd.encode()).hexdigest())).fetchone()
            c.close()
            if user:
                login_manager.record_attempt(email, True)
                self.current_user = dict(user)
                log_action(email, user["role"], "LOGIN", "SUCCESS")
                self.show_dashboard()
            else:
                login_manager.record_attempt(email, False)
                locked, rem = login_manager.is_locked(email)
                err.config(text=f"Аккаунт заблокирован на {rem}с." if locked else f"Неверные данные. Осталось: {MAX_ATTEMPTS-len(login_manager.attempts[email])}")
                log_action(email, "unknown", "LOGIN", "FAILED")
        ttk.Button(frm, text="Войти", style="Soft.TButton", command=do).pack(pady=20)
        frm.password_entry.bind("<Return>", lambda e: do())

    def show_register(self):
        self.log_and_show("register")
        self.clear_screen()
        colors = THEMES[self.theme]
        ttk.Button(self.root, text="← Назад", style="Soft.TButton", command=self.show_dashboard).place(x=20, y=20)
        frm = tk.Frame(self.root, bg=colors["card_bg"], highlightbackground=colors["card_border"], highlightthickness=1)
        frm.place(relx=0.5, rely=0.5, anchor="center", width=420, height=480)
        tk.Label(frm, text="📝 Регистрация", font=("Segoe UI", 20, "bold"), bg=colors["card_bg"], fg=colors["text"]).pack(pady=15)
        ents = {}
        for lbl, key, show in [("Email", "email", False), ("Пароль", "password", True), ("Подтвердите пароль", "confirm", True), ("Ваше имя", "full_name", False)]:
            tk.Label(frm, text=lbl, font=("Segoe UI", 10), bg=colors["card_bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            e = ttk.Entry(frm, style="Soft.TEntry")
            if show: e.config(show="*")
            e.pack(fill="x", padx=30, pady=3)
            ents[key] = e
        terms = tk.BooleanVar()
        ttk.Checkbutton(frm, text="Согласен с условиями и политикой конфиденциальности", variable=terms, style="Soft.TCheckbutton").pack(padx=30, pady=10)
        err = tk.Label(frm, text="", font=("Segoe UI", 9), bg=colors["card_bg"], fg=colors["danger"])
        err.pack()
        def do():
            email, pwd, conf, name = ents["email"].get().strip(), ents["password"].get(), ents["confirm"].get(), ents["full_name"].get().strip()
            v, e = validate_email(email)
            if not v: err.config(text=e); return
            v, e = validate_password(pwd)
            if not v: err.config(text=f"Пароль: {e}"); return
            if pwd != conf: err.config(text="Пароли не совпадают"); return
            if not name or len(name)<3: err.config(text="Имя минимум 3 символа"); return
            if not terms.get(): err.config(text="Требуется согласие"); return
            c = db()
            try:
                c.execute("INSERT INTO users(email,password,role,created_at) VALUES(?,?,?,?)", (email, hashlib.sha256(pwd.encode()).hexdigest(), "student", datetime.now().isoformat()))
                c.commit(); c.close()
                log_action(email, "student", "REGISTER", "SUCCESS")
                messagebox.showinfo("Успех", "Регистрация успешна!"); self.show_login()
            except sqlite3.IntegrityError: c.close(); err.config(text="Email уже занят"); log_action(email, "student", "REGISTER", "FAILED")
        ttk.Button(frm, text="Зарегистрироваться", style="Success.TButton", command=do).pack(pady=20)

