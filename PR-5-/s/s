                           font=("Arial", 12), bg="#f5f5f5", fg="#7f8c8d")
        subtitle.pack(pady=(0, 40))
        
        stats_frame = tk.Frame(content, bg="#f5f5f5")
        stats_frame.pack(fill="x")
        
        stats_data = [
            ("👥", "50k+", "Клиентов", "новых клиентов за год"),
            ("👨‍", "90+", "Учителя", "методистов помогают ученикам"),
            ("⭐", "99%", "Success", "довольных клиентов")
        ]
        
        for icon, value, title_text, desc in stats_data:
            stat_box = tk.Frame(stats_frame, bg="white", relief="raised", bd=2)
            stat_box.pack(side="left", fill="both", expand=True, padx=15, pady=10)
            
