    def show_register(self):
        self.log_and_show("register")
        self.clear_screen()
        colors = THEMES[self.theme]
        
        tk.Button(self.root, text="← Назад", font=("Arial", 10),
                 bg=colors["text_secondary"], fg="white", bd=0, padx=15, pady=5,
                 command=self.show_dashboard, cursor="hand2").place(x=20, y=20)
        
        reg_frame = tk.Frame(self.root, bg=colors["card_bg"], relief="raised", bd=3)
        reg_frame.place(relx=0.5, rely=0.5, anchor="center", width=420, height=500)
        
        tk.Label(reg_frame, text="📝 Регистрация", font=("Arial", 20, "bold"), 
                bg=colors["card_bg"], fg=colors["text"]).pack(pady=15)
        
        # Поля
        fields = [
            ("Email", "email", False),
            ("Пароль", "password", True),
            ("Подтвердите пароль", "confirm_password", True),
            ("Ваше имя", "full_name", False)  # Спецполе предметной области
        ]
        
        entries = {}
        for label, key, show in fields:
            tk.Label(reg_frame, text=label, font=("Arial", 10), 
                    bg=colors["card_bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            entry = tk.Entry(reg_frame, font=("Arial", 11), bd=2, relief="solid")
            if show:
                entry.config(show="*")
            entry.pack(fill="x", padx=30, pady=3)
            entries[key] = entry
            setattr(reg_frame, f"{key}_entry", entry)
        
        # Чекбокс согласия
        terms_var = tk.BooleanVar()
        tk.Checkbutton(reg_frame, 
            text="Согласен с условиями и политикой конфиденциальности",
            variable=terms_var, bg=colors["card_bg"], fg=colors["text"],
            font=("Arial", 9), anchor="w", selectcolor=colors["card_bg"]).pack(padx=30, pady=10)
        
        error_label = tk.Label(reg_frame, text="", font=("Arial", 9), 
                              bg=colors["card_bg"], fg=colors["danger"])
        error_label.pack()
        
        def do_register():
            email = entries["email"].get().strip()
            password = entries["password"].get()
            confirm = entries["confirm_password"].get()
            full_name = entries["full_name"].get().strip()
            
            # Валидации
            valid, err = validate_email(email)
            if not valid:
                error_label.config(text=err)
                return
            valid, err = validate_password(password)
            if not valid:
                error_label.config(text=f"Пароль: {err}")
                return
            if password != confirm:
                error_label.config(text="Пароли не совпадают")
                return
            if not full_name or len(full_name) < 3:
                error_label.config(text="Имя должно содержать минимум 3 символа")
                return
            if not terms_var.get():
                error_label.config(text="Необходимо согласие с условиями")
                return
            
            c = db()
            try:
                c.execute("INSERT INTO users(email,password,role,created_at) VALUES(?,?,?,?)",
                         (email, hashlib.sha256(password.encode()).hexdigest(), 
                          "student", datetime.now().isoformat()))
                c.commit()
                log_action(email, "student", "REGISTER", "SUCCESS")
                c.close()
                messagebox.showinfo("Успех", "Регистрация успешна! Войдите в систему.")
                self.show_login()
            except sqlite3.IntegrityError:
                c.close()
                error_label.config(text="Этот email уже зарегистрирован")
                log_action(email, "student", "REGISTER", "FAILED_EMAIL_EXISTS")
        
        tk.Button(reg_frame, text="Зарегистрироваться", font=("Arial", 12, "bold"),
                 bg=colors["success"], fg="white", bd=0, padx=20, pady=10,
                 command=do_register, cursor="hand2").pack(pady=20)

