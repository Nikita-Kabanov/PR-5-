    def toggle_theme(self, dark):
        self.theme = "dark" if dark else "light"
        self.config["theme"] = self.theme; save_config(self.config); self.apply_theme()
        log_action(self.current_user["email"] if self.current_user else "guest", self.current_user["role"] if self.current_user else "guest", "CHANGE_THEME", f"SUCCESS_{self.theme}")

    def export_enrollments(self, enrollments):
        if not enrollments: messagebox.showinfo("Экспорт", "Нет данных"); return
        path = f"exports/enrollments_{self.current_user['id']}_{datetime.now().strftime('%Y%m%d')}.csv"
        Path("exports").mkdir(exist_ok=True)
        with open(path, "w", newline="", encoding="utf-8-sig") as f:
            w = csv.writer(f); w.writerow(["Преподаватель", "Курс", "Цена", "Дата"])
            for e in enrollments: w.writerow(e)
        messagebox.showinfo("Экспорт", f"Сохранено: {path}")
        log_action(self.current_user["email"], self.current_user["role"], "EXPORT_ENROLLMENTS", "SUCCESS")

