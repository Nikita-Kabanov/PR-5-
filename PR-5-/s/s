    style.configure("Soft.Treeview", background=colors["card_bg"], fieldbackground=colors["card_bg"], foreground=colors["text"], rowheight=32, font=("Segoe UI", 9))
    style.configure("Soft.Treeview.Heading", font=("Segoe UI", 10, "bold"), background=colors["header_bg"], foreground=colors["header_fg"], padding=8)

