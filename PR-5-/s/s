    def show_login(self):
        self.log_and_show("login")
        self.clear_screen()
        colors = THEMES[self.theme]
        
        tk.Button(self.root, text="← Назад", font=("Arial", 10),
                 bg=colors["text_secondary"], fg="white", bd=0, padx=15, pady=5,
                 command=self.show_dashboard, cursor="hand2").place(x=20, y=20)
        
        login_frame = tk.Frame(self.root, bg=colors["card_bg"], relief="raised", bd=3)
        login_frame.place(relx=0.5, rely=0.5, anchor="center", width=400, height=380)
        
        tk.Label(login_frame, text="🔐 Вход", font=("Arial", 20, "bold"), 
                bg=colors["card_bg"], fg=colors["text"]).pack(pady=25)
        
        # Fields
        for label_text, entry_name in [("Email", "email"), ("Пароль", "password")]:
            tk.Label(login_frame, text=label_text, font=("Arial", 10), 
                    bg=colors["card_bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=30)
            entry = tk.Entry(login_frame, font=("Arial", 11), bd=2, relief="solid")
            entry.pack(fill="x", padx=30, pady=5)
            setattr(login_frame, f"{entry_name}_entry", entry)
        login_frame.password_entry.config(show="*")
        
        # Error & lockout
        error_label = tk.Label(login_frame, text="", font=("Arial", 9), 
                              bg=colors["card_bg"], fg=colors["danger"])
        error_label.pack()
        
        def do_login():
            email = login_frame.email_entry.get().strip()
            password = login_frame.password_entry.get()
            
            if not email or not password:
                error_label.config(text="Заполните все поля")
                return
            
            # Проверка блокировки
            locked, remaining = login_manager.is_locked(email)
            if locked:
                error_label.config(text=f"Слишком много попыток. Попробуйте через {remaining} сек.")
                login_frame.after(1000, do_login)  # Обновлять таймер
                return
            
            c = db()
            user = c.execute("SELECT * FROM users WHERE email=? AND password=?",
                           (email, hashlib.sha256(password.encode()).hexdigest())).fetchone()
            c.close()
            
            if user:
                login_manager.record_attempt(email, True)
                self.current_user = dict(user)
                log_action(email, user["role"], "LOGIN", "SUCCESS")
                self.show_dashboard()
            else:
                login_manager.record_attempt(email, False)
                locked, remaining = login_manager.is_locked(email)
                if locked:
                    error_label.config(text=f"Аккаунт заблокирован на {remaining} сек.")
                else:
                    attempts_left = MAX_ATTEMPTS - len(login_manager.attempts[email])
                    error_label.config(text=f"Неверные данные. Осталось попыток: {attempts_left}")
                log_action(email, "unknown", "LOGIN", "FAILED")
        
        tk.Button(login_frame, text="Войти", font=("Arial", 12, "bold"),
                 bg=colors["primary"], fg="white", bd=0, padx=30, pady=10,
                 command=do_login, cursor="hand2").pack(pady=20)
        
        login_frame.password_entry.bind("<Return>", lambda e: do_login())

