    def edit_teacher(self, teacher_id):
        colors = THEMES[self.theme]
        top = tk.Toplevel(self.root)
        top.title("Редактировать преподавателя")
        top.geometry("450x400")
        top.configure(bg=colors["bg"])
        
        c = db()
        teacher = c.execute("SELECT * FROM teachers WHERE id=?", (teacher_id,)).fetchone() if teacher_id else None
        c.close()
        
        tk.Label(top, text="✏️ Преподаватель", font=("Arial", 16, "bold"), 
                bg=colors["bg"], fg=colors["text"]).pack(pady=20)
        
        entries = {}
        for label, key, is_num in [("Имя*", "name", False), ("Описание", "description", False), ("Цена (₽)*", "price", True), ("Рейтинг", "rating", True)]:
            tk.Label(top, text=label, font=("Arial", 10), bg=colors["bg"], fg=colors["text_secondary"]).pack(anchor="w", padx=40)
            entry = tk.Entry(top, font=("Arial", 11), bd=2, relief="solid")
            if teacher:
                entry.insert(0, teacher[key])
            entry.pack(fill="x", padx=40, pady=3)
            entries[key] = entry
            setattr(top, f"{key}_entry", entry)
        
        error_label = tk.Label(top, text="", font=("Arial", 9), bg=colors["bg"], fg=colors["danger"])
        error_label.pack()
        
        def save():
            name = entries["name"].get().strip()
            price = entries["price"].get().strip()
            rating = entries["rating"].get().strip() or 0
            
            # Валидация
            if not name or len(name) < 3:
                error_label.config(text="Имя должно содержать минимум 3 символа")
                return
            try:
                price = float(price) if price else 0
                rating = float(rating) if rating else 0
            except ValueError:
                error_label.config(text="Цена и рейтинг должны быть числами")
                return
            
            # Проверка уникальности
            c = db()
            exists = c.execute("SELECT id FROM teachers WHERE name=? AND id!=?", (name, teacher_id or 0)).fetchone()
            if exists:
                error_label.config(text="Преподаватель с таким именем уже существует")
                c.close()
                return
            
            if teacher_id:
                c.execute("UPDATE teachers SET name=?, description=?, price=?, rating=? WHERE id=?",
                         (name, entries["description"].get(), price, rating, teacher_id))
                action = "UPDATE_TEACHER"
            else:
                c.execute("INSERT INTO teachers(name, description, price, rating) VALUES(?,?,?,?)",
                         (name, entries["description"].get(), price, rating))
                action = "CREATE_TEACHER"
            c.commit()
            c.close()
            
            log_action(self.current_user["email"], self.current_user["role"], action, "SUCCESS")
            messagebox.showinfo("Успех", "Сохранено!")
            top.destroy()
            self.show_teachers()
        
        tk.Button(top, text="💾 Сохранить", font=("Arial", 11, "bold"),
                 bg=colors["success"], fg="white", bd=0, padx=30, pady=8,
                 command=save, cursor="hand2").pack(pady=20)

