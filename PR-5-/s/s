            if c.execute("SELECT id FROM teachers WHERE name=? AND id!=?", (name, tid or 0)).fetchone(): err.config(text="Имя уже занято"); c.close(); return
            if tid: c.execute("UPDATE teachers SET name=?, description=?, price=?, rating=? WHERE id=?", (name, desc, price, rating, tid))
            else: c.execute("INSERT INTO teachers(name,description,price,rating) VALUES(?,?,?,?)", (name, desc, price, rating))
            c.commit(); c.close(); messagebox.showinfo("Успех", "Сохранено!"); top.destroy(); self.show_teachers()
